# ================================================================
# AI TRADER V16 AUTONOMOUS — SAFE DEFAULTS
# Start in analysis mode. Never paste real secrets into Git.
# ================================================================
EXECUTION_MODE=analysis
DAILY_TARGET_TIMEZONE=Asia/Yerevan
DATA_DIR=./data
LOGS_DIR=./logs
SHUTDOWN_ON_FATAL=true

TELEGRAM_TOKEN=
# Comma-separated Telegram user IDs allowed to control the bot.
AUTHORIZED_TELEGRAM_USER_IDS=
# Private notification chat ID; a positive value is also accepted as an authorized user ID.
CHAT_ID=
TELEGRAM_HANDLER_TIMEOUT=300000

# Bybit: analysis/paper may use RO keys. Live requires RW + acknowledgement.
BYBIT_MODE=ro
BYBIT_MARKET_TYPE=swap
BYBIT_POSITION_MODE=oneway
BYBIT_DEMO_TRADING=false
BYBIT_SANDBOX=false
BYBIT_API_KEY_RO=Db4sKuI6QEo3woT0Wh
BYBIT_API_SECRET_RO=7JgLjw9kwtxQoOojCscLKNQIJEHSmLkduRz1
BYBIT_API_KEY_RW=Db4sKuI6QEo3woT0Wh
BYBIT_API_SECRET_RW=ZdhFHbI54ifu8qiDY8ZyDuf2OGARDmWmxGd7
LIVE_TRADING_ACK=
# For live only, set exactly: I_ACCEPT_REAL_LOSS

# AI providers. Use model IDs actually available to your API account.
AI_PROVIDER=ensemble
ANTHROPIC_API_KEY=sk-ant-api03-zX0Vn9I3xhORu_f781bkqoJ1q8Glk5ipcFmyKH6ze3qxP6vmACXaqL5QGweRMu632mFEPNb9IgZNGHuGTNO6Ng-
CLAUDE_MODEL=claude-sonnet-5
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
ENSEMBLE_JUDGE=claude
AI_FAIL_CLOSED=true
AI_TIMEOUT_MS=60000
AI_MAX_RETRIES=2
AI_CIRCUIT_BASE_MS=15000
AI_CIRCUIT_MAX_MS=300000
REQUIRE_COMPLETE_ENSEMBLE_FOR_EXECUTION=true
REQUIRE_ENSEMBLE_DIRECTION_AGREEMENT=true

# Profit targets are stop/measurement controls, never guaranteed returns.
DAILY_SOFT_TARGET_PCT=2
DAILY_HARD_TARGET_PCT=5
SOFT_TARGET_RISK_MULTIPLIER=0.50
SOFT_TARGET_MAX_LEVERAGE=2

# Risk circuit breakers.
RISK_PER_TRADE_PCT=0.30
MAX_RISK_PER_TRADE_PCT=0.50
MAX_DAILY_LOSS_PCT=2
MAX_DAILY_GROSS_LOSS_PCT=3
MAX_WEEKLY_DRAWDOWN_PCT=6
MAX_CONSECUTIVE_LOSSES=2
MAX_TRADES_PER_DAY=10
MAX_OPEN_POSITIONS=10
MAX_PORTFOLIO_EXPOSURE_PCT=30
MAX_SYMBOL_EXPOSURE_PCT=12
MAX_MARGIN_PER_TRADE_PCT=8
MIN_RISK_REWARD=1.60
MIN_NET_RISK_REWARD=1.35
MIN_EXECUTION_SCORE=72
MIN_STOP_DISTANCE_PCT=0.25
MAX_STOP_DISTANCE_PCT=5

# Automatic execution never permits more than 5x.
AI_LEVERAGE_OPTIONS=1,2,3,5
MAX_AI_LEVERAGE=5

# Calibration.
MIN_CALIBRATION_SAMPLES=100
REQUIRE_CALIBRATION_FOR_LIVE=false
MIN_LIVE_CALIBRATION_SAMPLES=30
CALIBRATION_PRIOR_WINS=6
CALIBRATION_PRIOR_LOSSES=6

# Execution integrity.
MAX_ENTRY_DRIFT_PCT=0.35
MAX_SPREAD_PCT=0.20
SIGNAL_MAX_AGE_MS=120000
ORDER_TIMEOUT_MS=30000
PROTECTION_RETRIES=4
CLOSE_UNPROTECTED_POSITION=true
TPSL_TRIGGER_BY=markprice
TRADING_FEE_RATE=0.0006
ESTIMATED_SLIPPAGE_RATE=0.0005
ESTIMATED_FUNDING_RATE_8H=0.0001

# Scanner.
AUTO_TRADE_INTERVAL=90000
SCAN_TIMEFRAMES=15m,1h,4h
SCAN_STAGGER_MS=350
AI_SCAN_STAGGER_MS=1200
MAX_AI_ANALYSES_PER_SWEEP=8
MAX_AI_TIMEFRAMES_PER_COIN=1
MIN_PRESCAN_SCORE=40
AUTO_START_TRADING=false
PAPER_INITIAL_BALANCE=10000
USE_ONLY_CLOSED_CANDLES=true
ALLOW_MOCK_MARKET_DATA=false

# Backtest.
BACKTEST_INITIAL_BALANCE=10000
BACKTEST_RISK_PCT=0.50
BACKTEST_FEE_RATE=0.0006
BACKTEST_SLIPPAGE_RATE=0.0005
BACKTEST_FUNDING_RATE_8H=0.0001
