# AI TRADER V16.1 — FULL STATISTICS + PROVIDER FIXES

# Telegram
TELEGRAM_TOKEN=
CHAT_ID=
TELEGRAM_HANDLER_TIMEOUT=300000
BOT_INSTANCE_LOCK_PATH=./.ai-trader.lock

# Bybit
BYBIT_MODE=ro
BYBIT_MARKET_TYPE=swap
BYBIT_API_KEY_RO=
BYBIT_API_SECRET_RO=
BYBIT_API_KEY_RW=
BYBIT_API_SECRET_RW=

# AI ensemble
AI_PROVIDER=ensemble
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
CLAUDE_MODEL=claude-sonnet-5
DEEPSEEK_MODEL=deepseek-v4-pro
ENSEMBLE_JUDGE=claude

# Claude Sonnet 5 rejects non-default temperature/top_p/top_k.
# direct mode sends an exact payload without those sampling fields.
CLAUDE_API_MODE=direct
CLAUDE_TIMEOUT_MS=60000
REQUIRE_COMPLETE_ENSEMBLE=true
ALLOW_PARTIAL_ENSEMBLE=false
ALLOW_JUDGE_RESOLUTION=true
MIN_JUDGE_RESOLUTION_CONFIDENCE=82
DEEPSEEK_MAX_TOKENS=6000
DEEPSEEK_MAX_ATTEMPTS=3

# Targets are measurement/stop controls, never guaranteed returns.
DAILY_TARGET_MODE=percent
DAILY_SOFT_TARGET_PCT=2
DAILY_HARD_TARGET_PCT=5
DAILY_PROFIT_TARGET_USD=0
DAILY_TARGET_TIMEZONE=Asia/Yerevan
DAILY_PNL_SYNC_SECONDS=60
CAP_POSITION_TO_DAILY_TARGET=true
DAILY_TARGET_MAX_OVERSHOOT_PCT=10

# Hard risk limits
MAX_DAILY_LOSS_PCT=2
MAX_CONSECUTIVE_LOSSES=2
MAX_TRADES_PER_DAY=4
TRADE_COOLDOWN_MINUTES=60
RISK_PER_TRADE_PCT=0.35
MAX_RISK_PER_TRADE_PCT=0.50
MAX_OPEN_POSITIONS=2
MIN_RISK_REWARD=1.50
MIN_EXECUTION_SCORE=68
MIN_CALIBRATION_SAMPLES=100

# Leverage and exposure
AI_LEVERAGE_OPTIONS=1,2,3,5
MAX_AI_LEVERAGE=5
REQUIRE_AI_LEVERAGE_APPROVAL=true
ALLOW_AI_LEVERAGE_DOWNGRADE=true
MAX_MARGIN_PER_TRADE_PCT=8
MAX_PORTFOLIO_EXPOSURE_PCT=35
MAX_SYMBOL_EXPOSURE_PCT=12
MIN_STOP_DISTANCE_PCT=0.25
MAX_STOP_DISTANCE_PCT=10
MAX_WIDE_STOP_DISTANCE_PCT=10
APPROX_MAINTENANCE_MARGIN_RATE=0.005

# Account statistics
STATISTICS_TIMEZONE=Asia/Yerevan
STATISTICS_BACKFILL_DAYS=30
STATISTICS_RESYNC_DAYS=7
STATISTICS_SYNC_SECONDS=60
STATISTICS_MAX_ROWS=24
TRADING_DB_PATH=./trading.db

# Fees/backtest
TRADING_FEE_RATE=0.0006
BACKTEST_FEE_RATE=0.0006
BACKTEST_SLIPPAGE_RATE=0.0005
BACKTEST_FUNDING_RATE_8H=0.0001
BACKTEST_RISK_PCT=0.5
BACKTEST_INITIAL_BALANCE=10000

# Scanner
AUTO_TRADE_INTERVAL=90000
SCAN_TIMEFRAMES=15m,1h,4h
SCAN_STAGGER_MS=350
AI_SCAN_STAGGER_MS=1200
MAX_AI_ANALYSES_PER_SWEEP=8
MAX_SCAN_COINS=40
AUTO_TRADE_COINS=BTC,ETH,SOL,BNB,XRP,ADA,DOGE,AVAX,LINK,DOT
QUICK_SELECT_COINS=BTC,ETH,SOL,BNB,XRP,ADA,DOGE,AVAX,LINK,DOT

# Live execution timing
ORDER_FILL_TIMEOUT_MS=20000
ORDER_FILL_POLL_MS=1000

# Never enable mock market data in RW mode.
ALLOW_MOCK_MARKET_DATA=false

# V18 reliability and notification controls
CLAUDE_TIMEOUT_MS=90000
CLAUDE_RETRY_COUNT=3
SKIP_AI_WHEN_PORTFOLIO_FULL=true
SHOW_REPEATED_HOLD_NOTIFICATIONS=false
HOLD_NOTIFICATION_COOLDOWN_MINUTES=60
